# GitHub repo and branch to push generated model versions to
GIT_PUSH_REMOTE_URL=https://github.com/OpenBIM-Hackathon-Team-ECS-Version/File-Storage.git
GIT_PUSH_BRANCH=ifc-versions

# GitHub token with repo write access
GITHUB_TOKEN=replace-with-your-token

# Commit identity used by the server
GIT_USER_NAME=IFC Server
GIT_USER_EMAIL=ifc-server@localhost

# Optional advanced overrides
# VERSION_REPO_ROOT=C:/_LOCAL/GitHub/backend
# VERSION_DATA_REL_PATH=server/dataStores/fileBased/data

# Indexed snapshot storage backend:
# - filesystem: local dev / fallback
# - blob: durable Vercel Blob storage
# - auto: blob on Vercel when BLOB_READ_WRITE_TOKEN is set, otherwise filesystem
# PREINDEX_STORAGE_BACKEND=auto

# Local filesystem path override for indexed artifacts
# PREINDEX_ARTIFACTS_PATH=server/indexed-artifacts

# Durable Vercel Blob storage for indexed snapshots
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here
# PREINDEX_BLOB_PREFIX=indexed-artifacts

# Preindexing:
# - local default: enabled
# - Vercel default: disabled, because serverless functions should stay read/query focused
# PREINDEX_AUTOSTART=false
